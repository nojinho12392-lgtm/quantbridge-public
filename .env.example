# QuantBridge local configuration
# Copy to `.env` and fill secrets locally. `.env` is ignored by git.

QUANT_GOOGLE_KEY_PATH=./key.json
# Optional for cloud deploys/Codespaces. Use the full service-account JSON string.
QUANT_GOOGLE_KEY_JSON=
QUANT_SPREADSHEET_ID=1kn0Kp1QESSdwvmphCmaUFHNRh9qVUoN-2m_vMVDYHes
QUANT_SPREADSHEET_NAME=Jino_Quant_Database

# PostgreSQL service store
QUANT_ENABLE_POSTGRES=false
QUANT_DATABASE_URL=postgresql://quantbridge:quantbridge@localhost:5432/quantbridge

# DuckDB/Parquet research lake
QUANT_ENABLE_PARQUET=true
QUANT_DATA_LAKE_DIR=./data_lake

# API local auth/watchlist store
QUANT_API_SQLITE_PATH=./api/quantbridge.sqlite3
QUANT_API_BASE_URL=http://127.0.0.1:8000
QUANT_API_ENV=local
QUANT_CORS_ORIGINS=*
QUANT_AUTH_RATE_LIMIT_PER_MINUTE=20

# Optional Naver Search News API credentials. Keep real values out of git.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Optional Gemini news impact classifier. Leave GEMINI_API_KEY blank to use local rules only.
GEMINI_API_KEY=
NEWS_IMPACT_LLM_ENABLED=true
NEWS_IMPACT_LLM_MODEL=gemini-2.5-flash
NEWS_IMPACT_LLM_MAX_ITEMS=8
NEWS_IMPACT_LLM_TIMEOUT_SECONDS=8

# Optional phase-4 operations alert webhook. Leave blank to disable.
QUANT_OPS_WEBHOOK_URL=
QUANT_OPS_TIMEOUT_SECONDS=30

# Kiwoom credentials path
QUANT_KIWOOM_CREDENTIALS_PATH=./kiwoom_credentials.json

# legacy | prefect
QUANT_PIPELINE_RUNNER=prefect
